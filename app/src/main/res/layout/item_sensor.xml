<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/surface_section"
    app:cardCornerRadius="18dp"
    app:strokeColor="@color/outline_subtle"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/sensorNameView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/ink_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="BMI323 Accelerometer" />

        <TextView
            android:id="@+id/sensorMetaView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/brand_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="Accelerometer | Motion" />


        <TextView
            android:id="@+id/sensorCapabilityView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/ink_secondary"
            tools:text="Vendor Bosch | Range 39.2" />

        <TextView
            android:id="@+id/sensorStatusView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/ink_secondary"
            android:textSize="13sp"
            tools:text="" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
